NODE_ENV=production

# Core runtime
PORT=5000
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME?schema=public
JWT_SECRET=replace-with-a-random-secret-of-at-least-32-characters
SHUTDOWN_TIMEOUT_MS=10000

# Public URLs and allowed origins
CORS_ORIGINS=https://www.your-domain.tld,https://admin.your-domain.tld
FRONTEND_SITE_URL=https://www.your-domain.tld
UPLOAD_PUBLIC_BASE_URL=https://api.your-domain.tld

# Reverse proxy / HTTPS
TRUST_PROXY=true
ENABLE_HSTS=true
HSTS_MAX_AGE=31536000

# Session and CSRF cookies
AUTH_COOKIE_NAME=pizzeria_auth
CSRF_COOKIE_NAME=pizzeria_csrf
CSRF_HEADER_NAME=x-csrf-token
AUTH_COOKIE_SECURE=true
# Use none when frontend and backend are on different subdomains.
# Use lax when everything is served from the same site.
AUTH_COOKIE_SAMESITE=none
AUTH_COOKIE_MAX_AGE=604800000

# Uploads
UPLOAD_DIR=./uploads
UPLOAD_MAX_MB=5

# Emails
SMTP_HOST=smtp.your-provider.tld
SMTP_PORT=587
SMTP_USER=no-reply@your-domain.tld
SMTP_PASS=replace-with-your-smtp-password
SMTP_FROM="Pizzeria <no-reply@your-domain.tld>"
CONTACT_RECIPIENT_EMAIL=contact@your-domain.tld
PASSWORD_RESET_URL_BASE=https://www.your-domain.tld/reset-password
VERIFICATION_STRICT_DELIVERY=true

# Auth / profile behavior
DEFAULT_COUNTRY_DIAL_CODE=+33
EMAIL_OTP_TTL_MINUTES=10
PASSWORD_RESET_TTL_MINUTES=30
EMAIL_OTP_DEBUG_LOGGING=false
EXPOSE_EMAIL_OTP_IN_RESPONSE=false
CONTACT_DEBUG_LOGGING=false

# SEO / sitemap
SITEMAP_CACHE_SECONDS=300
# GOOGLE_SITE_VERIFICATION_FILE=google1234567890abcdef.html
# GOOGLE_SITE_VERIFICATION_CONTENT=google-site-verification: google1234567890abcdef.html

# Web push for the admin mobile app
# Leave empty if you do not enable push notifications yet.
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_SUBJECT=mailto:admin@your-domain.tld

# Print orchestration
PRINT_SCHEDULER_ENABLED=true
PRINT_SCHEDULER_INTERVAL_MS=2000
PRINT_JOB_LOCK_MS=60000
PRINT_RETRY_BASE_SECONDS=5
PRINT_RETRY_MAX_SECONDS=300
PRINT_DEFAULT_MAX_ATTEMPTS=5
PRINT_AGENT_OFFLINE_AFTER_MS=30000
PRINT_JOB_RETENTION_HOURS=24
PRINT_JOB_CLEANUP_INTERVAL_MS=60000
PRINT_READY_ALERT_AFTER_MINUTES=5
PRINT_READY_FAIL_AFTER_MINUTES=10
PRINT_REPRINT_READY_FAIL_AFTER_MINUTES=10

# Archived/deleted user placeholder
ARCHIVED_USER_EMAIL=archived-user@local.invalid
ARCHIVED_USER_NAME=Client supprime
ARCHIVED_USER_PHONE=+33100000000
